{
    "name": "frontend",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "build": "esbuild src/main.ts --bundle --outfile=dist/bundle.js --format=esm && copy src\\\\index.html dist\\\\index.html",
