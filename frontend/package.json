        "serve": "node .\\scripts\\buildShaders.js && copy src\\\\index.html dist\\\\index.html && esbuild src/main.ts --bundle --outfile=dist/bundle.js --format=esm --servedir=dist",
        "shaders": "node .\\scripts\\buildShaders.js",
        "clean": "powershell -Command \"Remove-Item -Path 'dist\\*' -Recurse -Force\""
    },
